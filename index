<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Leadership Simulation: Brink of Midnight</title>
    <style>
        body { font-family: 'Courier New', Courier, monospace; background: #0d0d0d; color: #00ff00; padding: 20px; }
        .container { max-width: 800px; margin: auto; border: 1px solid #00ff00; padding: 20px; box-shadow: 0 0 15px #00ff00; }
        .timer { font-size: 2em; text-align: center; color: #ff0000; }
        .prompt-box { background: #1a1a1a; padding: 15px; border-left: 5px solid #ffea00; margin-top: 20px; display: none; }
        button { background: #00ff00; color: black; border: none; padding: 10px 20px; cursor: pointer; font-weight: bold; }
        button:hover { background: #00cc00; }
    </style>
</head>
<body>
    <div class="container">
        <h1>SYSTEM: STRATEGIC DEFENSE FACILITATOR</h1>
        <p><strong>Assignment:</strong> Leadership Evaluation Simulation [cite: 1]</p>
        <hr>
        <div class="timer" id="timer">35:00</div>
        
        <h3>Active Roles:</h3>
        <ul>
            <li><strong>Sec. Defense:</strong> Just War Ethics [cite: 32]</li>
            <li><strong>Sec. State:</strong> Global Stability [cite: 3]</li>
            <li><strong>Sec. Transportation:</strong> Infrastructure & Evacuation [cite: 20]</li>
            <li><strong>Intel Director:</strong> Adversary EQ & Intent [cite: 32]</li>
        </ul>

        <button onclick="startSim()">INITIALIZE SIMULATION</button>
        <button onclick="nextPrompt()">TRIGGER LEADERSHIP INJECT</button>

        <div id="promptDisplay" class="prompt-box"></div>
    </div>

    <script>
        let timeLeft = 35 * 60;
        let prompts = [
            "ETHICS CHECK: Is a retaliatory strike 'just' if civilian casualties exceed 50%? [cite: 32]",
            "EQ CHECK: The team is arguing. As leaders, how do we lower the 'emotional temperature'? [cite: 32]",
            "INCLUSION CHECK: Sec. Transportation, how does your department's data change the current strategy? [cite: 21]",
            "FINAL CALL: 10 minutes remaining for consensus. Facilitate the vote now. [cite: 23]"
        ];
        let currentPrompt = 0;

        function startSim() {
            setInterval(() => {
                if (timeLeft <= 0) return;
                timeLeft--;
                let mins = Math.floor(timeLeft / 60);
                let secs = timeLeft % 60;
                document.getElementById('timer').innerText = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
            }, 1000);
        }

        function nextPrompt() {
            if (currentPrompt < prompts.length) {
                const box = document.getElementById('promptDisplay');
                box.style.display = 'block';
                box.innerText = prompts[currentPrompt];
                currentPrompt++;
            }
        }
    </script>
</body>
</html>
